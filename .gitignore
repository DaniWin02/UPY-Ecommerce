# =====================================================================
# Ágora Campus — .gitignore (Next.js / Node / TypeScript)
# =====================================================================

# Dependencias
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build / salida de Next.js
/.next
/out
/build
*.tsbuildinfo
next-env.d.ts

# Variables de entorno (nunca commitear secretos)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
# Sí permitimos el ejemplo público:
!.env.example

# Logs de gestores de paquetes
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Cobertura de pruebas
/coverage
*.lcov

# Playwright (reportes y artefactos de E2E)
playwright-report/
test-results/

# Certificados / claves
*.pem

# Sistema operativo
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea
*.swp

# Migraciones generadas por Drizzle (opcional — descomenta si no quieres versionarlas)
# /drizzle

# Comprobantes subidos (disco local, MVP)
uploads/

# =====================================================================
# Claude / herramientas de IA — no compartir en git
# Ocultamos los artefactos de Claude para que quien colabore SIN Claude
# tenga un repositorio limpio.
# =====================================================================
.claude/
.claude/**
.vercel

.vercel

# Material personal de presentación/video (no publicar en el repo)
guion-video-etl.html
etl-defensa/
