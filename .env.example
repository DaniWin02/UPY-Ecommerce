# ===========================================================================
# Ágora Campus — Variables de entorno (plantilla)
# Copia este archivo a .env y rellena los valores. NO subas .env al repo.
# ===========================================================================

# --- Base de datos (PostgreSQL) ---
# Cadena de conexión usada por Drizzle y pg-boss.
DATABASE_URL="postgresql://usuario:password@localhost:5432/agora"

# --- Auth.js v5 ---
# Secreto para firmar sesiones/tokens. Genera uno con: npx auth secret
AUTH_SECRET=""
# Credenciales de Google OAuth (gratis). Consola de Google Cloud → OAuth 2.0.
# Los nombres AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET son los que Auth.js v5
# autodetecta (no usar GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Remitente del magic link enviado vía Resend (provider Email de Auth.js).
# Con la API key de PRUEBA de Resend el remitente debe ser onboarding@resend.dev;
# con dominio propio verificado en Resend, usa tu dirección real.
EMAIL_FROM="Ágora Campus <noreply@tudominio.mx>"
# Dominios institucionales permitidos para iniciar sesión (separados por coma).
# Solo entra la comunidad verificada. Se admite con o sin "@" (se normaliza):
# "upy.edu.mx" y "@upy.edu.mx" son equivalentes.
ALLOWED_EMAIL_DOMAINS=alumno.upy.edu.mx,upy.edu.mx

# --- Gate global por IP (red del campus) ---
# Feature flag: si es "true", toda la tienda solo se abre desde la red escolar.
# Activable/desactivable también desde el panel admin.
#
# ADVERTENCIAS (léelas antes de encenderlo):
#  1. El gate confía en x-forwarded-for. Es fiable si tu plataforma/proxy
#     SOBRESCRIBE esa cabecera (Vercel sí) o si configuras TRUSTED_PROXIES
#     con el nº exacto de proxies propios que la "apendan" (nginx, etc.).
#  2. Solo IPv4 (y IPv6-mapeadas ::ffff:x.x.x.x). Si el campus tiene egreso
#     IPv6 real, esos usuarios quedarán BLOQUEADOS (fail-closed).
#  3. En dev local con el gate activo quedarás bloqueado (localhost suele ser
#     ::1, IPv6). Desarrolla con el gate apagado o consulta /api/ip-check.
IP_GATE_ENABLED="false"
# Rangos CIDR de la red/WiFi del campus (separados por coma).
# El middleware evalúa x-forwarded-for contra estos rangos.
# Ej: "10.0.0.0/8,192.168.1.0/24"
CAMPUS_CIDRS=""
# Nº de proxies PROPIOS delante de la app: la IP del cliente se toma de
# x-forwarded-for desde la DERECHA saltando este nº de entradas.
# 0 = server expuesto directo o plataforma que SOBRESCRIBE XFF (como Vercel).
# Con nginx propio que apenda XFF: cuenta cada salto (normalmente "1").
TRUSTED_PROXIES="0"
# Exige red del campus (CAMPUS_CIDRS) para el panel admin aunque el gate
# global (IP_GATE_ENABLED) esté apagado. Candado extra para /admin.
ADMIN_SOLO_IP_CAMPUS="false"

# --- Notificaciones ---
# Resend (correo): avisos de cambio de estado del pedido.
RESEND_API_KEY=""
# WhatsApp (Meta Cloud API / Twilio): "pago verificado / pedido listo".
WHATSAPP_TOKEN=""

# --- Almacenamiento de objetos (S3 compatible: Cloudflare R2 / MinIO / Supabase) ---
# Imágenes de producto y comprobantes de pago (URLs firmadas).
S3_ENDPOINT=""
S3_BUCKET="agora-campus"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"

# --- Testing ---
# Habilita /api/test/login: un bypass que crea sesiones SIN password para E2E.
# ¡¡NUNCA LO ENCIENDAS EN PRODUCCIÓN!! CUALQUIERA PODRÍA INICIAR SESIÓN COMO
# CUALQUIER USUARIO (INCLUIDO SUPERADMIN) CON UN SIMPLE POST.
E2E_TEST_MODE="false"

# --- Aplicación ---
# URL pública de la app (usada por Auth.js callbacks, correos y enlaces).
APP_URL="http://localhost:3000"
