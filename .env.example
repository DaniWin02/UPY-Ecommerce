# ===========================================================================
# Ágora Campus — Variables de entorno (plantilla)
# Copia este archivo a .env y rellena los valores. NO subas .env al repo.
# ===========================================================================

# --- Base de datos (PostgreSQL) ---
# Cadena de conexión usada por Drizzle y pg-boss.
DATABASE_URL="postgresql://usuario:password@localhost:5432/agora"

# --- Auth.js v5 ---
# Secreto para firmar sesiones/tokens. Genera uno con: npx auth secret
AUTH_SECRET=""
# Credenciales de Google OAuth (gratis). Consola de Google Cloud → OAuth 2.0.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Dominios institucionales permitidos para iniciar sesión (separados por coma).
# Solo entra la comunidad verificada. Ej: "@uni.mx" o "@uni.mx,@alumnos.uni.mx"
ALLOWED_EMAIL_DOMAINS="@uni.mx"

# --- Gate global por IP (red del campus) ---
# Feature flag: si es "true", toda la tienda solo se abre desde la red escolar.
# Activable/desactivable también desde el panel admin.
IP_GATE_ENABLED="false"
# Rangos CIDR de la red/WiFi del campus (separados por coma).
# El middleware evalúa x-forwarded-for contra estos rangos.
# Ej: "10.0.0.0/8,192.168.1.0/24"
CAMPUS_CIDRS=""

# --- Notificaciones ---
# Resend (correo): avisos de cambio de estado del pedido.
RESEND_API_KEY=""
# WhatsApp (Meta Cloud API / Twilio): "pago verificado / pedido listo".
WHATSAPP_TOKEN=""

# --- Almacenamiento de objetos (S3 compatible: Cloudflare R2 / MinIO / Supabase) ---
# Imágenes de producto y comprobantes de pago (URLs firmadas).
S3_ENDPOINT=""
S3_BUCKET="agora-campus"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"

# --- Aplicación ---
# URL pública de la app (usada por Auth.js callbacks, correos y enlaces).
APP_URL="http://localhost:3000"
